# ============================================================
# 环境变量模板 (.env.example)
# 复制为 .env.dev 或 .env.prod，按需填写后使用
# ============================================================

# 环境标识（dev | prod）
VEHIVLE_APP_ENV=dev

# 数据库（必填）
VEHIVLE_DATABASE_DSN=postgres://user:password@localhost:5432/vehivle?sslmode=disable

# Redis（可选）
VEHIVLE_REDIS_ADDR=localhost:6379
VEHIVLE_REDIS_PASSWORD=

# OSS（媒体上传时必填）
VEHIVLE_OSS_ACCESS_KEY=
VEHIVLE_OSS_SECRET_KEY=
VEHIVLE_OSS_BUCKET=vehivle-media
VEHIVLE_OSS_REGION=ap-guangzhou

# JWT（认证时必填）
VEHIVLE_JWT_SECRET=your-32-byte-secret-key-here
