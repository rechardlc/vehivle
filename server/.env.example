# ============================================================
# 环境变量模板 (.env.example)
# 复制为 .env.dev 或 .env.prod，按需填写后使用
# ============================================================

# 环境标识（dev | prod）
VEHIVLE_APP_ENV=dev

# 数据库（必填）
VEHIVLE_DATABASE_DSN=postgres://user:password@localhost:5432/vehivle?sslmode=disable

# Redis（可选）
VEHIVLE_REDIS_ADDR=localhost:6379
VEHIVLE_REDIS_PASSWORD=

# OSS（媒体上传时必填）
VEHIVLE_OSS_ENDPOINT=http://localhost:9000
VEHIVLE_OSS_ACCESS_KEY=vehivle
VEHIVLE_OSS_SECRET_KEY=vehivle123
VEHIVLE_OSS_BUCKET=vehivle-media
VEHIVLE_OSS_REGION=us-east-1
# API 在 Docker 内且 endpoint 为 http://minio:9000 时，填浏览器可打开的 MinIO 地址（无路径）
# VEHIVLE_OSS_PUBLIC_URL=http://localhost:9000
# 是否启动时为 Bucket 设置匿名可读（开发 true；生产一般用 CDN/签名 URL，保持 false）
# VEHIVLE_OSS_ENABLE_PUBLIC_READ=true

# JWT（认证时必填）
VEHIVLE_JWT_SECRET=your-32-byte-secret-key-here
